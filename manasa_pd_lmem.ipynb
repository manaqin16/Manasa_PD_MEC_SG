import pandas as pd
lf = pd.read_csv('/content/long_data.csv')
display(lf.head())

print("Dataset size (rows, columns):", lf.shape)
print("\nMissing values per column:")
print(lf.isnull().sum())


lf_sorted = lf.sort_values(by=['LinkageID', 'timepoint'])
lf_filled = lf_sorted.groupby('LinkageID')['ethnicity_cat'].transform(lambda x: x.ffill())
lf['ethnicity_cat'] = lf_filled
print("Missing values in ethnicity_cat after filling:")
print(lf['ethnicity_cat'].isnull().sum())


lf_sorted = lf.sort_values(by=['LinkageID', 'timepoint'])
lf_sorted['k10sum'] = lf_sorted.groupby('LinkageID')['k10sum'].ffill()
lf['k10sum'] = lf_sorted['k10sum']
print("Missing values in k10sum after filling:")
print(lf['k10sum'].isnull().sum())


print("Data types of columns (excluding 'LinkageID'):")
print(lf.drop(columns=['LinkageID']).dtypes)
lf['gender'] = lf['gender'].astype('int64')
lf['ethnicity_cat'] = lf['ethnicity_cat'].astype('int64')

# value labels for categorical variables
cognition_labels = {1: 'cognitively impaired', 0: 'not cognitively impaired'}
education_labels = {1: 'no formal education', 2: 'primary education', 3: 'secondary education'}
age_cat_labels = {1: 'age 40-50', 2: 'age 51-60', 3: 'age 61 and above'}
ethnicity_labels = {1: 'chinese', 2: 'malay', 3: 'indian'}
working_status_labels = {1: 'working', 2: 'not working'}
marital_status_labels = {1: 'never married', 2: 'currently married', 3: 'separated/widowed/divorced'}
alcohol_cat_labels = {0: 'consumes alcohol', 1: 'doesnt consume alcohol'}
regularmed_labels = {1: 'on medication', 2: 'not on medication'}
pmh_any_labels = {1: 'yes', 2: 'no'}
bmi_cat_labels = {1: 'underweight', 2: 'normal', 3: 'overweight', 4: 'obese'}
income_cat_labels = {1: 'income below 6000SGD', 2: 'income above 6000SGD'}
house_cat_labels = {1: 'hdb 1-3 room', 2: 'hdb 4-5 room/executive flat', 3: 'private housing'}
gender_labels = {1: 'male', 2: 'female'}
smoking_labels = {1: 'never smoker', 2: 'past smoker', 3: 'current smoker'}
pd_labels = {1: 'High PD', 0: 'Low or No PD'}

# Apply value labels
lf['cognition_cat'] = lf['cognition_cat'].replace(cognition_labels)
lf['education'] = lf['education'].replace(education_labels)
lf['age_cat'] = lf['age_cat'].replace(age_cat_labels)
lf['ethnicity_cat'] = lf['ethnicity_cat'].replace(ethnicity_labels)
lf['working_status'] = lf['working_status'].replace(working_status_labels)
lf['marital_status'] = lf['marital_status'].replace(marital_status_labels)
lf['alcohol_cat'] = lf['alcohol_cat'].replace(alcohol_cat_labels)
lf['regularmed'] = lf['regularmed'].replace(regularmed_labels)
lf['pmh_any'] = lf['pmh_any'].replace(pmh_any_labels)
lf['bmi_cat'] = lf['bmi_cat'].replace(bmi_cat_labels)
lf['income_cat'] = lf['income_cat'].replace(income_cat_labels)
lf['house_cat'] = lf['house_cat'].replace(house_cat_labels)
lf['gender'] = lf['gender'].replace(gender_labels)
lf['smoking_status'] = lf['smoking_status'].replace(smoking_labels)
lf['pd_cat'] = lf['pd_cat'].replace(pd_labels)

# Display the updated data with value labels
display(lf.head())

# Identify continuous variables
continuous_cols = ['k10sum', 'age', 'bmi', 'whr']

# Calculate mean and standard deviation and create standardized columns
for col in continuous_cols:
    mean_val = lf[col].mean()
    std_val = lf[col].std()
    lf[f'{col}_std'] = (lf[col] - mean_val) / std_val
display(lf.head())

